---
// Contact form wired to Formspree (replaces the reference's unreliable mailto).
// Submits via fetch so we can show inline success/error without leaving the page;
// falls back to a normal POST if JS is unavailable.
import { FORMSPREE_ENDPOINT, CONTACT_EMAIL } from '../lib/site';

const fieldStyle =
  'background:rgba(255,255,255,0.1);border:none;padding:0.7rem 0.9rem;font:400 1rem \'Hanken Grotesk\';color:#fff;outline:none;';
---

<form
  id="contact-form"
  action={FORMSPREE_ENDPOINT}
  method="POST"
  style="display:flex;flex-direction:column;gap:1.3rem;background:rgba(255,255,255,0.07);padding:clamp(1.6rem,3vw,2.4rem);"
>
  <label style="display:flex;flex-direction:column;gap:0.45rem;">
    <span class="lbl" style="font-size:0.56rem;color:rgba(255,255,255,0.6);">Your name</span>
    <input type="text" name="name" required style={fieldStyle} />
  </label>
  <label style="display:flex;flex-direction:column;gap:0.45rem;">
    <span class="lbl" style="font-size:0.56rem;color:rgba(255,255,255,0.6);">Your email</span>
    <input type="email" name="email" required style={fieldStyle} />
  </label>
  <label style="display:flex;flex-direction:column;gap:0.45rem;">
    <span class="lbl" style="font-size:0.56rem;color:rgba(255,255,255,0.6);"
      >What's on your mind</span
    >
    <textarea
      name="message"
      rows="3"
      style={`${fieldStyle}line-height:1.5;resize:vertical;`}></textarea>
  </label>
  <!-- Honeypot: bots fill this; humans never see it. -->
  <input
    type="text"
    name="_gotcha"
    tabindex="-1"
    autocomplete="off"
    aria-hidden="true"
    style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;"
  />
  <button
    data-mag
    type="submit"
    style="align-self:flex-start;background:var(--cy);color:var(--ink);border:none;cursor:pointer;padding:0.9rem 1.8rem;font:600 0.94rem/1 'Hanken Grotesk';transition:transform .15s;"
    >Send it →</button
  >
  <p
    id="contact-status"
    role="status"
    aria-live="polite"
    style="display:none;font:500 0.9rem/1.5 'Hanken Grotesk';margin:0;"
  >
  </p>
</form>

<script define:vars={{ CONTACT_EMAIL, FORMSPREE_ENDPOINT }}>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('contact-status');
  const btn = form?.querySelector('button[type="submit"]');

  // If the endpoint hasn't been configured yet, don't pretend to submit.
  const configured = !FORMSPREE_ENDPOINT.includes('xxxxxxxx');

  function show(msg, ok) {
    if (!status) return;
    status.textContent = msg;
    status.style.display = 'block';
    status.style.color = ok ? 'var(--cy)' : '#FFD9D9';
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!configured) {
      show(
        'Form endpoint not configured yet — set FORMSPREE_ENDPOINT in src/lib/site.ts. Meanwhile, email ' +
          CONTACT_EMAIL +
          '.',
        false
      );
      return;
    }
    const data = new FormData(form);
    const original = btn?.textContent;
    if (btn) {
      btn.disabled = true;
      btn.textContent = 'Sending…';
    }
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        form.reset();
        show("Thanks — your message is in. I read every one and will reply personally.", true);
      } else {
        const body = await res.json().catch(() => ({}));
        const detail = body?.errors?.map((x) => x.message).join(', ');
        show(detail || 'Something went wrong. Please email ' + CONTACT_EMAIL + '.', false);
      }
    } catch {
      show('Network error. Please email ' + CONTACT_EMAIL + '.', false);
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.textContent = original || 'Send it →';
      }
    }
  });
</script>
