---
// POST-LAUNCH: "Quality at Scale" case-study walkthrough modal.
// Built in full but hidden for launch. It only opens when a case has
// hasModal:true (which renders the "View the work →" trigger button).
// With CASES[2].hasModal=false there is no trigger, so this stays inert.
//
// To go live: flip CASES[2].hasModal to true in src/lib/site.ts and drop real
// screenshots into the four gallery slots below (see README POST-LAUNCH).
import { QAS_PAIN, QAS_STEPS, QAS_OUTCOMES, QAS_GALLERY, CONTACT_EMAIL } from '../lib/site';
---

<div
  id="case-modal"
  data-case-modal
  hidden
  style="position:fixed;inset:0;z-index:1000;background:rgba(10,12,14,0.55);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);display:flex;justify-content:center;align-items:flex-start;overflow:auto;padding:clamp(0.6rem,3vw,2.6rem);"
>
  <div
    class="caseModal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="case-modal-title"
    data-modal-panel
    style="background:var(--pp);color:var(--ink);width:min(940px,100%);max-width:940px;box-shadow:0 40px 120px rgba(0,0,0,0.45);position:relative;"
  >
    <div
      style="position:sticky;top:0;z-index:2;background:var(--ink);color:var(--pp);padding:clamp(1.6rem,3.2vw,2.6rem) clamp(1.4rem,3.2vw,2.8rem);"
    >
      <button
        data-modal-close
        aria-label="Close"
        style="position:absolute;top:clamp(1rem,2vw,1.5rem);right:clamp(1rem,2vw,1.5rem);width:40px;height:40px;border:1px solid rgba(255,255,255,0.35);background:transparent;color:#fff;cursor:pointer;font-size:1.1rem;line-height:1;display:flex;align-items:center;justify-content:center;transition:background .2s ease;"
        >✕</button
      >
      <div style="display:flex;align-items:baseline;gap:0.9rem;flex-wrap:wrap;">
        <span class="lbl" style="font-size:0.64rem;color:var(--cy);">Quality at Scale</span>
        <span class="lbl" style="font-size:0.56rem;color:rgba(233,238,244,0.6);"
          >Design &amp; experience</span
        >
      </div>
      <h2
        id="case-modal-title"
        class="ser"
        style="font-size:clamp(1.5rem,2.8vw,2.3rem);line-height:1.08;margin:1rem 0 0;max-width:26ch;color:#fff;"
      >
        Relaunching iOS and Android without letting the bar drop.
      </h2>
      <div class="lbl" style="font-size:0.56rem;color:rgba(233,238,244,0.6);margin-top:1rem;">
        Relaunch · New GTM · Scaling past PMF
      </div>
    </div>

    <div
      style="padding:clamp(1.6rem,3.4vw,3rem) clamp(1.4rem,3.4vw,2.8rem) clamp(2rem,4vw,3.4rem);"
    >
      <div
        class="casegrid"
        style="display:grid;grid-template-columns:8rem 1fr;gap:clamp(1rem,2.4vw,2rem);align-items:start;"
      >
        <span class="lbl" style="font-size:0.6rem;color:var(--mut);padding-top:0.35rem;"
          >The pain</span
        >
        <p
          class="ser"
          style="font-style:italic;font-family:'Newsreader',serif;font-size:clamp(1.15rem,1.9vw,1.5rem);line-height:1.36;color:var(--ink);max-width:44ch;"
        >
          {QAS_PAIN}
        </p>
      </div>
      <hr style="border:none;border-top:1px solid var(--line);margin:clamp(1.6rem,3vw,2.4rem) 0;" />

      <div
        class="casegrid"
        style="display:grid;grid-template-columns:8rem 1fr;gap:clamp(1rem,2.4vw,2rem);align-items:start;"
      >
        <span class="lbl" style="font-size:0.6rem;color:var(--mut);padding-top:0.35rem;"
          >What I did</span
        >
        <div style="display:flex;flex-direction:column;gap:1.1rem;max-width:62ch;">
          {
            QAS_STEPS.map((text, j) => (
              <div style="display:grid;grid-template-columns:2.4rem 1fr;gap:0.9rem;align-items:start;">
                <span class="ser" style="font-size:1.05rem;color:var(--ind);line-height:1.6;">
                  {String(j + 1).padStart(2, '0')}
                </span>
                <p style="font-size:1rem;line-height:1.66;color:#363C46;">{text}</p>
              </div>
            ))
          }
        </div>
      </div>
      <hr style="border:none;border-top:1px solid var(--line);margin:clamp(1.6rem,3vw,2.4rem) 0;" />

      <div
        class="casegrid"
        style="display:grid;grid-template-columns:8rem 1fr;gap:clamp(1rem,2.4vw,2rem);align-items:start;"
      >
        <span class="lbl" style="font-size:0.6rem;color:var(--mut);padding-top:0.35rem;"
          >The proof</span
        >
        <div>
          <div
            style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:0;border-top:2px solid var(--ink);"
          >
            {
              QAS_OUTCOMES.map((o) => (
                <div style="padding:1.2rem 1.2rem 1.4rem 0;">
                  <div
                    class="ser"
                    style="font-size:clamp(1.7rem,2.6vw,2.3rem);line-height:0.95;color:var(--ind);"
                  >
                    {o.val}
                  </div>
                  <p style="font-size:0.84rem;line-height:1.45;color:#4C5560;margin-top:0.45rem;max-width:20ch;">
                    {o.label}
                  </p>
                </div>
              ))
            }
          </div>
          <p
            class="ser"
            style="font-style:italic;font-family:'Newsreader',serif;font-size:clamp(1.2rem,1.9vw,1.55rem);line-height:1.3;color:var(--ind);margin-top:1.8rem;max-width:42ch;"
          >
            Quality that scaled with the product, instead of being spent to ship it.
          </p>
        </div>
      </div>

      <div style="margin-top:clamp(1.8rem,3.4vw,2.6rem);">
        <span class="lbl" style="font-size:0.6rem;color:var(--mut);">The visual proof</span>
        <p style="font-size:0.9rem;line-height:1.55;color:#4C5560;max-width:56ch;margin:0.5rem 0 0.9rem;">
          Real screens, the clickable prototype, and the design system – the walkthrough goes deeper.
        </p>
        <div
          class="casegrid"
          style="display:grid;grid-template-columns:1fr 1fr;gap:clamp(0.8rem,2vw,1.4rem);"
        >
          {
            QAS_GALLERY.map((g) => (
              <figure style="margin:0;">
                {/* Empty gallery slot — supply a real screenshot post-launch. */}
                <div
                  id={g.slot}
                  data-image-slot
                  style="display:flex;align-items:center;justify-content:center;text-align:center;width:100%;height:clamp(220px,26vw,300px);border:1px solid var(--line);background:var(--bd);color:var(--mut);"
                >
                  <span class="lbl" style="font-size:0.5rem;padding:0 1rem;">{g.ph}</span>
                </div>
                <figcaption class="lbl" style="font-size:0.52rem;color:var(--mut);margin-top:0.5rem;">
                  {g.ph}
                </figcaption>
              </figure>
            ))
          }
        </div>
      </div>

      <div
        style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-top:clamp(1.8rem,3vw,2.4rem);padding-top:1.4rem;border-top:1px solid var(--line);"
      >
        <button
          data-modal-close
          style="background:transparent;border:1px solid var(--ink);color:var(--ink);cursor:pointer;padding:0.8rem 1.4rem;font:600 0.85rem/1 'Hanken Grotesk';"
          >← Back to work</button
        >
        <a
          href={`mailto:${CONTACT_EMAIL}?subject=Quality%20at%20Scale%20walkthrough`}
          style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--ind);color:#fff;text-decoration:none;padding:0.82rem 1.5rem;font:600 0.88rem/1 'Hanken Grotesk';"
          >Request the full walkthrough →</a
        >
      </div>
    </div>
  </div>
</div>

<script>
  const modal = document.querySelector<HTMLElement>('[data-case-modal]');
  const panel = modal?.querySelector<HTMLElement>('[data-modal-panel]');
  if (modal && panel) {
    const reduced = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches ?? false;

    const open = () => {
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      if (!reduced) {
        modal.style.animation = 'camo .25s ease';
        panel.style.animation = 'capanel .38s cubic-bezier(.2,.85,.25,1)';
      }
      modal.querySelector<HTMLElement>('[data-modal-close]')?.focus();
    };
    const close = () => {
      modal.hidden = true;
      document.body.style.overflow = '';
    };

    // Only wired when a "View the work →" trigger exists (hasModal:true).
    document
      .querySelectorAll<HTMLElement>('[data-open-modal]')
      .forEach((b) => b.addEventListener('click', open));

    modal.addEventListener('click', (e) => {
      if (e.target === modal) close(); // click outside panel
    });
    modal
      .querySelectorAll<HTMLElement>('[data-modal-close]')
      .forEach((b) => b.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) close();
    });
  }
</script>
