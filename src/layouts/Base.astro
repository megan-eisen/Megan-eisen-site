---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Container max-width: 1180px on Megan, 1120px on Óptimo. */
  wrMax?: string;
  /** Social share image, relative to site root. 1200x630. */
  ogImage?: string;
  ogImageAlt?: string;
  /** og:type — 'profile' for Megan's page, 'website' for Óptimo. */
  ogType?: string;
  /** JSON-LD structured data object for this page. */
  jsonLd?: Record<string, unknown>;
  /** Keep this page out of search results (used by 404). */
  noindex?: boolean;
}

const {
  title,
  description,
  wrMax = '1180px',
  ogImage = '/og-megan.jpg',
  ogImageAlt = 'Megan Eisen',
  ogType = 'website',
  jsonLd,
  noindex = false,
} = Astro.props;

// Bump when the logo/icons change, to bust the browser's favicon cache.
const ICON_V = '2';

// Absolute URLs — required by Open Graph / Twitter and for canonicals.
// Astro's default `directory` build format emits /optimo/index.html, which
// GitHub Pages serves at /optimo/ (301 from /optimo). Keep the trailing slash
// so the canonical points at the final URL rather than a redirect, and matches
// what @astrojs/sitemap emits.
const pathname = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const canonical = new URL(pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="author" content="Megan Eisen" />
    <meta
      name="robots"
      content={
        noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large, max-snippet:-1'
      }
    />
    <meta name="theme-color" content="#14161A" />
    <meta name="color-scheme" content="light" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Megan Eisen" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!--
      Icons. /favicon.ico must exist: browsers request it from the domain root
      automatically and cache it hard per-origin — without it, a favicon cached
      from a previous site at this domain sticks around. `?v=` busts that cache;
      bump ICON_V in this file whenever the logo changes.
    -->
    <link rel="icon" href={`/favicon.ico?v=${ICON_V}`} sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href={`/favicon-32.png?v=${ICON_V}`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`/favicon-16.png?v=${ICON_V}`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`/apple-touch-icon.png?v=${ICON_V}`} />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts: Gloock (display), Newsreader (italic accent), Hanken Grotesk (UI) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Gloock&family=Newsreader:ital,opsz,wght@0,6..72,400..600;1,6..72,400..600&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }

    <style is:global define:vars={{ wrMax }}>
      :root {
        --wr-max: var(--wrMax);
      }
    </style>
  </head>
  <body>
    <slot />
    <script>
      import { initMotion } from '../scripts/motion';
      // Run after the DOM is parsed. Astro places module scripts at end of body,
      // so the DOM is already available, but guard just in case.
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initMotion);
      } else {
        initMotion();
      }
    </script>
  </body>
</html>
