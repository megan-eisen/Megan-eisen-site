---
import Base from '../layouts/Base.astro';
import CaseModal from '../components/CaseModal.astro';
import ContactForm from '../components/ContactForm.astro';
import {
  CITIES,
  SNAPSHOT,
  BUILT_INSIDE,
  CASES,
  TIMELINE,
  CONTACT_EMAIL,
  LINKEDIN_URL,
  INSTAGRAM_URL,
} from '../lib/site';

const homeCity = CITIES.filter((c) => c.home);
const others = CITIES.filter((c) => !c.home);

// Hero headline split into words for the reveal + pointer-lean effects.
const heroWords: { text: string; accent?: boolean }[] = [
  { text: 'I' },
  { text: 'hold' },
  { text: 'the' },
  { text: 'business,' },
  { text: 'the' },
  { text: 'product,' },
  { text: 'and' },
  { text: 'the' },
  { text: 'customer' },
  { text: 'experience' },
  { text: 'together' },
  { text: '– from', accent: true },
  { text: 'founder-led', accent: true },
  { text: 'to', accent: true },
  { text: 'Fortune 500.', accent: true },
];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Megan Eisen',
  url: 'https://meganeisen.com',
  image: 'https://meganeisen.com/og-megan.jpg',
  jobTitle: 'Product, Design & Business Operations Executive',
  email: `mailto:${CONTACT_EMAIL}`,
  description:
    'Executive leading business, product, and customer experience — from founder-led companies to Fortune 500. Founder of the advisory practice Óptimo.',
  sameAs: [LINKEDIN_URL, INSTAGRAM_URL],
  worksFor: {
    '@type': 'Organization',
    name: 'Óptimo',
    url: 'https://meganeisen.com/optimo',
  },
  knowsAbout: [
    'Product management',
    'Design leadership',
    'Business operations',
    'Customer experience',
    'Operating models',
    'Hospitality and travel technology',
    'Post-acquisition integration',
  ],
};
---

<Base
  title="Megan Eisen — Product, Design & Business Operations Executive"
  description="Executive leading business, product, and customer experience — from founder-led to Fortune 500. Former Chief Experience Officer of The Infatuation. Founder of Óptimo."
  wrMax="1180px"
  ogImage="/og-megan.jpg"
  ogImageAlt="Megan Eisen"
  ogType="profile"
  jsonLd={personSchema}
>
  <!-- HEADER -->
  <header
    style="position:sticky;top:0;z-index:100;background:rgba(239,242,246,0.9);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid var(--ink);"
  >
    <div
      class="wr"
      style="height:66px;display:flex;align-items:center;justify-content:space-between;gap:1.5rem;"
    >
      <a href="/" style="display:flex;align-items:center;gap:0.55rem;text-decoration:none;">
        <img src="/assets/logo-megan.png" alt="Megan Eisen" style="height:23px;width:auto;" />
        <span class="ser" style="font-size:1.12rem;">Megan Eisen</span>
      </a>
      <nav class="nav" style="display:flex;align-items:center;gap:1.6rem;">
        <a class="spy" data-spy="work" href="#work">Work</a>
        <a class="spy" data-spy="about" href="#about">About</a>
        <a href="/optimo">Óptimo →</a>
      </nav>
      <div style="display:flex;align-items:center;gap:1.1rem;">
        <a
          data-mag
          href="#contact"
          style="background:var(--ink);color:var(--pp);padding:0.58rem 1.1rem;font:600 0.78rem/1 'Hanken Grotesk';text-decoration:none;white-space:nowrap;transition:transform .15s;"
          >Let's talk</a
        >
      </div>
    </div>
  </header>

  <!-- HERO -->
  <section id="top" style="padding:clamp(2.6rem,5vw,4.5rem) 0 clamp(2.2rem,4vw,3.4rem);">
    <div
      class="wr herogrid"
      style="display:grid;grid-template-columns:1.05fr 0.95fr;gap:clamp(2rem,5vw,4rem);align-items:center;"
    >
      <div>
        <span class="lbl" style="color:var(--ind);"
          >Founder • Óptimo – Exec • Product, Design, Business Ops</span
        >
        <h1
          data-recal
          data-kinetic
          class="ser"
          style="font-size:clamp(1.85rem,3.4vw,3.05rem);line-height:1.04;letter-spacing:-0.012em;margin-top:1.4rem;max-width:26ch;"
        >
          {
            heroWords.map((w, i) => (
              <>
                <span class="rw" style="display:inline-block;">
                  {w.accent ? (
                    <span data-i style="color:var(--ind);" set:html={w.text} />
                  ) : (
                    <Fragment set:html={w.text} />
                  )}
                </span>
                {i < heroWords.length - 1 ? ' ' : ''}
              </>
            ))
          }
        </h1>
        <p
          style="font-size:clamp(1rem,1.25vw,1.14rem);line-height:1.62;color:#4C5560;max-width:54ch;margin-top:1.5rem;"
        >
          Twenty years leading business, product, and experience across hospitality and travel –
          where the experience is the product. Most recently Chief Experience Officer, carrying
          <strong style="color:var(--ink);font-weight:600;">The Infatuation</strong> through its
          acquisition by <strong style="color:var(--ink);font-weight:600;">JPMorganChase</strong>.
          Now, through <strong style="color:var(--ink);font-weight:600;">Óptimo</strong>, I do it
          for founders and teams at their hardest moments of change.
        </p>
        <div
          style="display:flex;gap:1rem;align-items:center;flex-wrap:wrap;margin-top:1.9rem;"
        >
          <a
            data-mag
            href="#contact"
            style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--ind);color:#fff;text-decoration:none;padding:0.92rem 1.7rem;font:600 0.92rem/1 'Hanken Grotesk';white-space:nowrap;transition:transform .15s;"
            >Let's talk →</a
          >
        </div>
      </div>

      <!-- HERO MEDIA: photo + live tracker -->
      <div>
        <figure data-offset-parent style="margin:0;position:relative;">
          <div
            data-offset-block
            style="position:absolute;right:-0.7rem;top:-0.7rem;width:26%;height:26%;background:var(--cy);z-index:1;"
          >
          </div>
          <div style="position:relative;background:var(--ind);overflow:hidden;">
            <img
              data-par
              src="/assets/megan-glasses.jpeg"
              alt="Megan Eisen"
              class="heroimg"
              style="position:relative;z-index:0;"
            />
          </div>
        </figure>
        <div
          style="border:1px solid var(--ink);border-top:none;padding:0.85rem 1rem;background:var(--bd);"
        >
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <span class="lbl" style="font-size:0.54rem;color:var(--ink);">Working globally</span>
            <span style="display:flex;align-items:center;gap:0.4rem;"
              ><span
                style="width:6px;height:6px;border-radius:50%;background:var(--cy);animation:pdot 2.2s ease-out infinite;"
              ></span><span class="lbl" style="font-size:0.5rem;color:var(--ind);">Live</span></span
            >
          </div>
          <div style="margin-top:0.85rem;display:flex;flex-direction:column;gap:0.7rem;">
            {
              homeCity.map((c) => (
                <div style="background:var(--ink);color:var(--pp);padding:0.8rem 1rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;">
                  <div>
                    <div style="display:flex;align-items:center;gap:0.5rem;">
                      <span
                        data-dot={c.tz}
                        data-home="true"
                        style="width:9px;height:9px;border-radius:50%;background:var(--cy);flex-shrink:0;"
                      />
                      <span style="font:600 1rem/1.1 'Hanken Grotesk';color:#fff;">{c.name}</span>
                    </div>
                    <div class="lbl" style="font-size:0.5rem;color:var(--cy);margin-top:0.45rem;">
                      {c.tag}
                    </div>
                  </div>
                  <div
                    data-clock={c.tz}
                    class="clk"
                    style="font:600 clamp(1.7rem,2.4vw,2.1rem)/1 'Hanken Grotesk';color:#fff;"
                  >
                    --:--
                  </div>
                </div>
              ))
            }
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.8rem;">
              {
                others.map((c) => (
                  <div style="border-left:1px solid var(--line);padding-left:0.7rem;">
                    <div style="display:flex;align-items:center;gap:0.45rem;">
                      <span
                        data-dot={c.tz}
                        data-home="false"
                        style="width:7px;height:7px;border-radius:50%;background:var(--line);flex-shrink:0;"
                      />
                      <span style="font:600 0.78rem/1.1 'Hanken Grotesk';">{c.name}</span>
                    </div>
                    <div
                      data-clock={c.tz}
                      class="clk"
                      style="font:600 1.02rem/1 'Hanken Grotesk';color:var(--ink);margin-top:0.45rem;"
                    >
                      --:--
                    </div>
                    <div class="lbl" style="font-size:0.48rem;color:var(--mut);margin-top:0.3rem;">
                      {c.tag}
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SNAPSHOT -->
  <section
    id="snapshot"
    style="padding:clamp(2.8rem,5vw,4.4rem) 0;border-top:1px solid var(--ink);background:var(--bd);scroll-margin-top:66px;"
  >
    <div class="wr">
      <div
        style="display:flex;align-items:baseline;justify-content:space-between;gap:1rem;flex-wrap:wrap;"
      >
        <span class="lbl" style="color:var(--ind);">Executive snapshot</span>
        <span class="lbl" style="font-size:0.54rem;color:var(--mut);"
          >As of 2026 · Working globally</span
        >
      </div>
      <h2
        data-reveal
        class="ser"
        style="font-size:clamp(1.7rem,3vw,2.6rem);line-height:1.08;margin:0.9rem 0 1.6rem;max-width:24ch;"
      >
        Business, experience, and product leadership at <span data-i style="color:var(--ind);"
          >company-defining moments.</span
        >
      </h2>
      <div
        style="border:1px solid var(--ink);background:var(--pp);box-shadow:0 16px 40px rgba(20,30,50,0.10);"
      >
        <div style="display:grid;grid-template-columns:repeat(4,1fr);" class="snapgrid">
          {
            SNAPSHOT.map((s) => (
              <div
                data-reveal
                style="padding:1.5rem 1.4rem 1.7rem;border-right:1px solid var(--line);border-bottom:1px solid var(--line);"
              >
                <div
                  class="ser"
                  data-count
                  style="font-size:clamp(1.6rem,2.5vw,2.25rem);line-height:1;color:var(--ind);"
                >
                  {s.stat}
                </div>
                <p style="font-size:0.86rem;line-height:1.5;color:#4C5560;margin-top:0.7rem;">
                  {s.desc}
                </p>
              </div>
            ))
          }
        </div>
        <div
          style="display:flex;align-items:baseline;gap:clamp(0.8rem,2vw,1.4rem);flex-wrap:wrap;padding:1rem 1.4rem;border-top:1px solid var(--ink);"
        >
          <span class="lbl" style="font-size:0.56rem;color:var(--mut);">Built inside</span>
          <span style="font:600 0.86rem/1.7 'Hanken Grotesk';color:var(--ink);">{BUILT_INSIDE}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SELECTED WORK -->
  <section
    id="work"
    style="position:relative;overflow:hidden;padding:clamp(3.2rem,5.5vw,5.5rem) 0;border-top:1px solid var(--ink);background:var(--ink);color:var(--pp);scroll-margin-top:66px;"
  >
    <div class="wr">
      <span class="lbl" style="color:var(--cy);">Selected work</span>
      <h2
        data-reveal
        class="ser"
        style="font-size:clamp(1.9rem,3.6vw,3rem);line-height:1.08;margin:1.1rem 0 0;max-width:20ch;color:#fff;"
      >
        Proof at the points of <span data-i style="color:var(--cy);">inflection.</span>
      </h2>
      <p
        style="font-size:1rem;line-height:1.66;color:rgba(233,238,244,0.78);max-width:64ch;margin-top:1.2rem;"
      >
        The hardest moments in a company's life aren't the failures – they're the successes. Scaling
        past product-market fit. Being acquired. Launching. Consolidating. A leadership change.
        That's where the business, the product, and the customer experience pull apart – and where I
        do my sharpest work.
      </p>

      <div
        style="margin-top:clamp(2.4rem,4vw,3.4rem);display:flex;gap:1.4rem;overflow-x:auto;padding-bottom:1.2rem;scroll-snap-type:x mandatory;"
      >
        {
          CASES.map((h) => (
            <div
              data-reveal
              class="casecard"
              style="flex:0 0 auto;width:clamp(320px,82vw,460px);scroll-snap-align:start;padding:clamp(1.6rem,3vw,2.2rem);background:rgba(255,255,255,0.05);display:flex;flex-direction:column;gap:1.2rem;align-items:stretch;transition:background .25s ease,transform .25s ease;"
            >
              <div>
                <span class="lbl" style="font-size:0.72rem;color:var(--cy);">
                  {h.label}
                </span>
                <div
                  class="lbl"
                  style="font-size:0.56rem;color:rgba(233,238,244,0.55);margin-top:0.6rem;"
                >
                  {h.discipline}
                </div>
                <div style="font-size:0.82rem;color:rgba(233,238,244,0.68);margin-top:1rem;line-height:1.55;">
                  {h.tags}
                </div>
              </div>
              <div>
                <p
                  class="ser"
                  style="font-style:italic;font-family:'Newsreader',serif;font-size:clamp(1.3rem,2.1vw,1.8rem);line-height:1.24;color:#fff;max-width:36ch;"
                >
                  “{h.pain}”
                </p>
                <p style="font-size:0.98rem;line-height:1.64;color:rgba(233,238,244,0.8);margin-top:1.1rem;max-width:58ch;">
                  {h.did}
                </p>
                <div style="display:flex;flex-wrap:wrap;gap:1.4rem 2.6rem;margin-top:1.5rem;">
                  {h.proof.map((r) => (
                    <div>
                      <div
                        class="ser"
                        style="font-size:clamp(1.3rem,2vw,1.7rem);line-height:0.9;color:var(--cy);"
                        data-count
                      >
                        {r.val}
                      </div>
                      <p style="font-size:0.74rem;line-height:1.35;color:rgba(233,238,244,0.6);margin-top:0.4rem;max-width:18ch;">
                        {r.label}
                      </p>
                    </div>
                  ))}
                </div>
                <div style="display:flex;align-items:center;gap:1.6rem;flex-wrap:wrap;margin-top:1.7rem;">
                  {h.hasModal && (
                    <button
                      data-open-modal
                      style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--cy);color:var(--ink);border:none;cursor:pointer;padding:0.72rem 1.3rem;font:600 0.82rem/1 'Hanken Grotesk';"
                    >
                      View the work →
                    </button>
                  )}
                  <a
                    href={`mailto:${CONTACT_EMAIL}?subject=Request%20the%20full%20walkthrough`}
                    style="font:600 0.82rem/1 'Hanken Grotesk';color:var(--cy);text-decoration:none;border-bottom:1px solid rgba(10,255,251,0.45);padding-bottom:3px;"
                  >
                    Request the full walkthrough →
                  </a>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <p
        style="font-size:0.94rem;line-height:1.6;color:rgba(233,238,244,0.7);max-width:56ch;margin-top:clamp(1.8rem,3vw,2.4rem);"
      >
        Full context, process, constraints, and outcomes on request.
      </p>
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section
    id="experience"
    style="position:relative;overflow:hidden;padding:clamp(3.2rem,5vw,5rem) 0;border-top:1px solid var(--ink);background:var(--bd);scroll-margin-top:66px;"
  >
    <div class="wr">
      <div
        class="expgrid"
        style="display:grid;grid-template-columns:0.92fr 1.08fr;gap:clamp(2rem,5vw,4.5rem);align-items:start;"
      >
        <div>
          <span class="lbl" style="color:var(--mut);">Experience</span>
          <h2
            class="ser"
            style="font-size:clamp(1.7rem,3vw,2.5rem);line-height:1.08;margin-top:0.8rem;max-width:16ch;"
          >
            Two decades, five continents, every stage of <span data-i>growth.</span>
          </h2>
          <p style="font-size:1rem;line-height:1.7;color:#4C5560;margin-top:1.1rem;max-width:48ch;">
            Started in Nebraska, Colorado, Hawaii, St. Croix. Navigated 15 countries before landing
            in Singapore, Germany, Miami. Now between New York City, Switzerland, and Mexico
            <span style="color:var(--ind);font-weight:600;">→ working globally.</span>
          </p>
          <p style="font-size:0.96rem;line-height:1.7;color:#565E68;margin-top:1rem;max-width:48ch;">
            The arc of my journey reads customer experience → design → product: all with business
            leadership and hospitality/travel at the core. A pattern that repeats itself: leading
            design, earning the product org, and being asked to step into company strategy and
            leadership. At every company, the job kept growing – I'd lead one thing, then get handed
            the next. I don't sit still well. Ask anyone I've worked with.
          </p>
        </div>
        <div>
          <div
            class="lbl"
            style="font-size:0.6rem;color:var(--ind);padding-bottom:0.9rem;border-bottom:2px solid var(--ink);"
          >
            Career timeline
          </div>
          <ul style="list-style:none;">
            {
              TIMELINE.map((t) => (
                <li style="padding:1.1rem 0;border-bottom:1px solid var(--line);">
                  <div style="display:flex;justify-content:space-between;align-items:baseline;gap:1rem;">
                    <span style="font-size:1.02rem;line-height:1.3;font-weight:600;color:var(--ink);">
                      {t.role}
                    </span>
                    <span
                      class="lbl"
                      style="font-size:0.56rem;color:var(--mut);white-space:nowrap;"
                    >
                      {t.date}
                    </span>
                  </div>
                  <span style="display:block;font-size:0.9rem;color:#4C5560;margin-top:0.3rem;">
                    {t.org}
                  </span>
                </li>
              ))
            }
          </ul>
          <p style="font-size:0.9rem;line-height:1.7;color:#565E68;margin-top:1.3rem;">
            <strong style="color:var(--ink);font-weight:600;">Before 2019</strong> – founding and
            operating roles plus product, customer-experience, and hospitality leadership: EveryBell,
            Cognita Schools, HRS Group, Four Seasons, and Intuit.
            <a
              href={`mailto:${CONTACT_EMAIL}?subject=Executive%20r%C3%A9sum%C3%A9%20request`}
              style="color:var(--ind);text-decoration:none;border-bottom:1.5px solid var(--ind);"
              >Request résumé →</a
            >
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHO I AM · TABBED -->
  <section
    id="about"
    style="position:relative;overflow:hidden;padding:clamp(3.2rem,5.5vw,5.5rem) 0;border-top:1px solid var(--ink);scroll-margin-top:66px;"
  >
    <div class="wr">
      <div
        style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;"
      >
        <span class="lbl" style="color:var(--mut);">The person you'd work with</span>
        <div style="display:inline-flex;border:1px solid var(--ink);" role="tablist">
          <button
            id="tab-work"
            role="tab"
            aria-selected="true"
            data-tab-btn="work"
            style="cursor:pointer;border:none;background:#14161A;color:#EFF2F6;padding:0.6rem 1.1rem;font:600 0.72rem/1 'Hanken Grotesk';letter-spacing:0.1em;text-transform:uppercase;"
            >At work</button
          >
          <button
            id="tab-human"
            role="tab"
            aria-selected="false"
            data-tab-btn="human"
            style="cursor:pointer;border:none;background:transparent;color:#7B818B;padding:0.6rem 1.1rem;font:600 0.72rem/1 'Hanken Grotesk';letter-spacing:0.1em;text-transform:uppercase;"
            >As a human</button
          >
        </div>
      </div>
      <div
        class="forkgrid"
        style="display:grid;grid-template-columns:1.1fr 0.9fr;gap:clamp(1.8rem,4vw,3.2rem);align-items:center;margin-top:1.6rem;"
      >
        <div>
          <div data-tab-panel="work" style="display:block;">
            <h2 class="ser" style="font-size:clamp(1.8rem,3vw,2.6rem);line-height:1.1;max-width:20ch;">
              Megan – at work <span data-i style="color:var(--ind);">anywhere in the world.</span>
            </h2>
            <p style="font-size:1.04rem;line-height:1.74;color:#39414C;max-width:50ch;margin-top:1.1rem;">
              I read a business by where it drags, not where it hurts. A customer-experience problem
              is usually an ownership problem. A drifting roadmap is usually a revenue problem. An AI
              ambition is usually a data-and-identity problem – most companies want AI features; far
              fewer have built the foundation AI actually runs on. My job is to find the layer
              creating the drag and rebuild what the business has outgrown – not by adding process,
              but by making the system visible enough that decisions move again.
            </p>
            <p style="font-size:1.04rem;line-height:1.74;color:#39414C;max-width:50ch;margin-top:1rem;">
              I start with the business itself – strategy, org design, how decisions get made, and
              the budget that funds them. Then the experience: what the customer, user, or guest
              actually meets. Then the product and the craft that delivers it. Most executives own
              one of the three. I've led all three, and I hold them together exactly when scale is
              pulling them apart.
            </p>
          </div>
          <div data-tab-panel="human" style="display:none;">
            <h2 class="ser" style="font-size:clamp(1.8rem,3vw,2.6rem);line-height:1.1;max-width:22ch;">
              Megan – <span data-i style="color:var(--ind);">as a human.</span>
            </h2>
            <p style="font-size:1.04rem;line-height:1.74;color:#39414C;max-width:50ch;margin-top:1.1rem;">
              I've moved across the world with two suitcases, which is roughly how I work: light,
              fast, and useful anywhere within weeks. I design my life the way I design an operating
              model – deliberately, around what actually matters, with nothing carried that doesn't
              earn its place. Experiences over things. Ownership over titles. Time and location on my
              own terms.
            </p>
            <p style="font-size:1.04rem;line-height:1.74;color:#39414C;max-width:50ch;margin-top:1rem;">
              I've explored 29 countries across five continents with my wife, and we are always
              mapping the next one. I love the wind in my hair, sunshine, fresh air, alpine cheese,
              exploring cultures different than mine. I'm inspired by the creativity of humans and
              being "Auntie" makes me happy. I'm into working with hands, growing and building are my
              happy place, plating nightly is my creativity. My Swiss-Mexican wife is my everything.
            </p>
          </div>
        </div>
