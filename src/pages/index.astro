<!-- About-tab toggle: swaps text, portrait, and caption. -->
<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('[data-tab-btn]');
  const panels = document.querySelectorAll<HTMLElement>('[data-tab-panel]');
  const tabOn =
    "cursor:pointer;border:none;background:#14161A;color:#EFF2F6;padding:0.6rem 1.1rem;font:600 0.72rem/1 'Hanken Grotesk';letter-spacing:0.1em;text-transform:uppercase;";
  const tabOff =
    "cursor:pointer;border:none;background:transparent;color:#7B818B;padding:0.6rem 1.1rem;font:600 0.72rem/1 'Hanken Grotesk';letter-spacing:0.1em;text-transform:uppercase;";

  function setTab(tab: string) {
    btns.forEach((b) => {
      const on = b.dataset.tabBtn === tab;
      b.setAttribute('style', on ? tabOn : tabOff);
      b.setAttribute('aria-selected', String(on));
    });
    panels.forEach((p) => {
      const on = p.dataset.tabPanel === tab;
      // Images/figcaptions restore to block; text panels to block too.
      p.style.display = on ? (p.tagName === 'IMG' ? 'block' : 'block') : 'none';
    });
  }
  btns.forEach((b) => b.addEventListener('click', () => setTab(b.dataset.tabBtn!)));
</script>
